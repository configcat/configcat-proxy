## Environment ##
NODE_ENV=production

## Server ##
PORT=8081
HOST=localhost

## Setup jet-logger ##
JET_LOGGER_MODE=CONSOLE
JET_LOGGER_TIMESTAMP=TRUE
JET_LOGGER_FORMAT=LINE

## ------------------------- ##
## ------- CONFIGCAT ------- ##
## ------------------------- ##

## -------- GENERAL CONFIGURATION --------- ##

## SDK_KEY ##
## SDK Key to access your feature flags and configurations. Get it from ConfigCat Dashboard. ##
SDK_KEY=

## DATA_GOVERNANCE ##
## Describes the location of your feature flag and setting data within the ConfigCat CDN. ##
## This parameter needs to be in sync with your Data Governance preferences. ##
## Read more at https://configcat.com/docs/advanced/data-governance. ##
## Available options: Global, EuOnly. ##
DATA_GOVERNANCE=Global

## POLLING_MODE ##
## The ConfigCat SDK supports 3 different polling mechanisms to acquire the setting values from ConfigCat. ## 
## Read more at https://configcat.com/docs/sdk-reference/node/#polling-modes. ##
## Available options: AutoPoll, LazyLoad, ManualPoll. ##
POLLING_MODE=AutoPoll

## REQUEST_TIMEOUT_MS ## 
## The amount of milliseconds the SDK waits for a response from the ConfigCat servers before returning values from the cache. ##
REQUEST_TIMEOUT_MS=30000

## ---- AUTO POLLING MODE CONFIGURATION --- ##

## AUTOPOLL__POLL_INTERVAL_SECONDS ##
## Polling interval. Range: 1 - Number.MAX_SAFE_INTEGER ##
AUTOPOLL__POLL_INTERVAL_SECONDS=60

## AUTOPOLL__MAX_INIT_WAIT_TIME_SECONDS ##
## Maximum waiting time between the client initialization and the first config acquisition in seconds. ##
AUTOPOLL__MAX_INIT_WAIT_TIME_SECONDS=5


## ---- LAZY LOADING MODE CONFIGURATION --- ##

## LAZYLOAD__CACHE_TIME_TO_LIVE_SECONDS ##
## Maximum waiting time between the client initialization and the first config acquisition in seconds. ##
LAZYLOAD__CACHE_TIME_TO_LIVE_SECONDS=60